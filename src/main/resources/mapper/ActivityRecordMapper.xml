<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.saori.npo.mapper.ActivityRecordMapper">

    <resultMap
        id="activityRecordResultMap"
        type="com.saori.npo.domain.ActivityRecord">

        <id property="id" column="id" />
        <result property="organizationId" column="organization_id" />
        <result property="fiscalYear" column="fiscal_year" />
        <result property="projectName" column="project_name" />
        <result property="content" column="content" />
        <result property="result" column="result" />
        <result property="reportFileName" column="report_file_name" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />

    </resultMap>

    <select
        id="findAll"
        resultMap="activityRecordResultMap">

        SELECT
            *
        FROM
            activity_records
        ORDER BY
            fiscal_year DESC,
            project_name ASC

    </select>

    <select
        id="findById"
        parameterType="long"
        resultMap="activityRecordResultMap">

        SELECT
            *
        FROM
            activity_records
        WHERE
            id = #{id}

    </select>

    <insert
        id="insert"
        parameterType="com.saori.npo.domain.ActivityRecord"
        useGeneratedKeys="true"
        keyProperty="id">

        INSERT INTO activity_records (
            organization_id,
            fiscal_year,
            project_name,
            content,
            result,
            report_file_name,
            created_at,
            updated_at
        )
        VALUES (
            #{organizationId},
            #{fiscalYear},
            #{projectName},
            #{content},
            #{result},
            #{reportFileName},
            NOW(),
            NOW()
        )

    </insert>

    <update
        id="update"
        parameterType="com.saori.npo.domain.ActivityRecord">

        UPDATE
            activity_records
        SET
            fiscal_year = #{fiscalYear},
            project_name = #{projectName},
            content = #{content},
            result = #{result},
            report_file_name = #{reportFileName},
            updated_at = NOW()
        WHERE
            id = #{id}

    </update>

    <delete
        id="deleteById"
        parameterType="long">

        DELETE FROM
            activity_records
        WHERE
            id = #{id}

    </delete>

</mapper>